FROM swr.cn-south-1.myhuaweicloud.com/ascendhub/{{ item.tag }}
MAINTAINER tommylike <tommylikehu@gmail.com>

##############
# User: root #
##############
# Set env
USER root
ENV USER root

# Set bash
RUN ln -sf bash /bin/sh

# Install base tools
RUN yum update -y && \
    yum install -y vim \
    zip \
    tree \
    dos2unix \
    sudo \
    bzip2 \
    pigz \
    gtest gtest-devel \
    gtest-devel \
    gawk \
    nlohmann-json-devel \
    patch \
    && yum clean all
    
# Install googletest
RUN git clone --depth 1 -b {{ item.google_version }} https://github.com/google/googletest.git /tmp/googletest && \
    cd /tmp/googletest && \
    mkdir build && \
    cd build && \
    cmake .. && \
    make && \
    make install && \
    rm -rf /tmp/googletest

# Install python plugin 
RUN mkdir /root/.pip \
    && echo "[global]" > /root/.pip/pip.conf \
    && echo "index-url={{ item.pip_index_url }}" >> /root/.pip/pip.conf \
    && echo "trusted-host={{ item.pip_trusted_host }} " >> /root/.pip/pip.conf \
    && echo "timeout=120" >> /root/.pip/pip.conf \
    && pip3 install --upgrade pip && cd /tmp \
    && pip3 install wheel=={{ item.wheel_version }} \
    && pip3 install pyyaml=={{ item.pyyaml_version }} \
    && pip3 install setuptools=={{ item.setuptools_version }}  \
    && pip3 install numpy=={{ item.numpy_version }}  \
    && pip3 install attrs \
    && pip3 install decorator \
    && pip3 install sympy \
    && pip3 install psutil \
    && pip3 install scipy \
    && pip3 install protobuf

WORKDIR /opt
